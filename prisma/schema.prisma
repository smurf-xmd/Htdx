datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  SUPER_ADMIN
  MODERATOR
  USER
}

enum SubscriptionPlan {
  FREE
  PREMIUM
  ENTERPRISE
}

model User {
  id                    String                @id @default(cuid())
  email                 String                @unique
  username              String                @unique
  passwordHash          String
  fullName              String?
  role                  UserRole              @default(USER)
  subscriptionPlan      SubscriptionPlan      @default(FREE)
  isEmailVerified       Boolean               @default(false)
  isSuspended           Boolean               @default(false)
  avatar                String?
  bots                  Bot[]
  deployments           Deployment[]
  refreshTokens         RefreshToken[]
  emailVerifications    EmailVerification[]
  passwordResets        PasswordReset[]
  activityLogs          ActivityLog[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  lastLoginAt           DateTime?
  @@index([email])
  @@index([username])
  @@index([isSuspended])
}

model RefreshToken {
  id                    String                @id @default(cuid())
  userId                String
  token                 String                @unique
  expiresAt             DateTime
  createdAt             DateTime              @default(now())
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([expiresAt])
}

model EmailVerification {
  id                    String                @id @default(cuid())
  userId                String
  token                 String                @unique
  expiresAt             DateTime
  createdAt             DateTime              @default(now())
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([token])
}

model PasswordReset {
  id                    String                @id @default(cuid())
  userId                String
  token                 String                @unique
  expiresAt             DateTime
  createdAt             DateTime              @default(now())
  usedAt                DateTime?
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([token])
}

enum BotStatus {
  DRAFT
  DEPLOYED
  RUNNING
  STOPPED
  FAILED
  DELETED
}

model Bot {
  id                    String                @id @default(cuid())
  userId                String
  name                  String
  description           String?
  status                BotStatus             @default(DRAFT)
  startupFile           String
  startupCommand        String?
  filePath              String                @unique
  pm2ProcessId          Int?
  pm2Name               String?
  ramLimitMB            Int                   @default(512)
  cpuLimit              Int?
  uploadedAt            DateTime              @default(now())
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  deletedAt             DateTime?
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  deployments           Deployment[]
  files                 BotFile[]
  environmentVariables  EnvironmentVariable[]
  @@index([userId])
  @@index([status])
  @@index([deletedAt])
}

model BotFile {
  id                    String                @id @default(cuid())
  botId                 String
  fileName              String
  filePath              String
  fileSize              Int
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  bot                   Bot                   @relation(fields: [botId], references: [id], onDelete: Cascade)
  @@index([botId])
  @@unique([botId, filePath])
}

model EnvironmentVariable {
  id                    String                @id @default(cuid())
  botId                 String
  key                   String
  value                 String
  isSensitive           Boolean               @default(true)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  bot                   Bot                   @relation(fields: [botId], references: [id], onDelete: Cascade)
  @@index([botId])
  @@unique([botId, key])
}

enum DeploymentStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
  ROLLED_BACK
}

model Deployment {
  id                    String                @id @default(cuid())
  botId                 String
  userId                String
  status                DeploymentStatus      @default(PENDING)
  version               Int
  logs                  String?               @db.LongText
  errorMessage          String?
  pm2ProcessId          Int?
  startedAt             DateTime?
  stoppedAt             DateTime?
  uptime                Int?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  bot                   Bot                   @relation(fields: [botId], references: [id], onDelete: Cascade)
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([botId])
  @@index([userId])
  @@index([status])
}

enum ActivityType {
  USER_REGISTERED
  USER_LOGIN
  USER_LOGOUT
  BOT_UPLOADED
  BOT_DEPLOYED
  BOT_STARTED
  BOT_STOPPED
  BOT_RESTARTED
  BOT_DELETED
  FILE_EDITED
  ENV_UPDATED
  PLAN_UPGRADED
  PLAN_DOWNGRADED
  USER_SUSPENDED
  ADMIN_ACTION
}

model ActivityLog {
  id                    String                @id @default(cuid())
  userId                String
  activityType          ActivityType
  description           String
  ipAddress             String?
  userAgent             String?
  botId                 String?
  createdAt             DateTime              @default(now())
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([activityType])
  @@index([createdAt])
}

model Announcement {
  id                    String                @id @default(cuid())
  title                 String
  message               String                @db.LongText
  severity              String                @default("info")
  isActive              Boolean               @default(true)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  expiresAt             DateTime?
  @@index([isActive])
}

model SubscriptionPlanConfig {
  id                    String                @id @default(cuid())
  plan                  SubscriptionPlan      @unique
  maxBots               Int?
  maxRamPerBot          Int
  maxCpuPercent         Int?
  maxStorageGB          Int?
  price                 Decimal               @db.Decimal(10, 2)
  billingCycle          Int
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
}